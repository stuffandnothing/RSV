#!/bin/bash
# rsv - runit service manager wrapper
# Usage: rsv [--user] <command> [service]

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

if [[ -n "${NO_COLOR-}" ]]; then
    RED='' GREEN='' YELLOW='' BLUE='' BOLD='' NC=''
fi
_hint() {
    local msg="${1:-}"
    [[ -n "$msg" ]] && echo -e "${YELLOW}hint${NC}: ${msg}"
}
_info()    { echo -e "${BLUE}==>${NC} ${BOLD}$*${NC}"; }
_ok()      { echo -e "${GREEN}ok${NC}: $*"; }
_warn()    { echo -e "${YELLOW}warn${NC}: $*"; }
_error() {
    local msg="${1:-an unknown error occurred}"
    local no_exit="${2:-}"
    echo -e "${RED}error${NC}: ${msg}"
    [[ -z "$no_exit" ]] && exit 1
}
_error_hint() {
    local msg="${1:-an unknown error occurred}"
    local hint="${2:-}"
    echo -e "${RED}error${NC}: ${msg}"
    _hint "$hint"
    exit 1
}
# --- Mode selection -----------------------------------------------------------

USER_MODE=0
if [[ "$1" == "--user" ]]; then
    USER_MODE=1
    shift
elif [[ $EUID -ne 0 ]]; then
    USER_MODE=1
fi

if [[ $USER_MODE -eq 1 ]]; then
    SVDIR="${RUNIT_SVDIR:-$HOME/.runit/sv}"
    RUNSVDIR="${RUNIT_RUNSVDIR:-$HOME/.runit/runsvdir}"
    LOG_FILE="${RUNIT_LOG:-$HOME/.runit/log/everything/current}"
    ROOT_SVDIR="/etc/runit/sv"
else
    SVDIR="/etc/runit/sv"
    RUNSVDIR="/etc/runit/runsvdir/default"
    SV_SOCK_DIR=""
    LOG_FILE="/var/log/everything/current"
fi

# Strip flag args and set variables
NOW=0
LOG_LEVEL=""
LOG_LINES=10
WITH_LOG=0
AS_USER=""
_args=()
_next_level=0
_next_as_user=0
_next_lines=0
for _a in "$@"; do
    if [[ $_next_level -eq 1 ]]; then
        LOG_LEVEL="${_a//,/|}"
        _next_level=0
    elif [[ $_next_as_user -eq 1 ]]; then
        AS_USER="$_a"
        _next_as_user=0
    elif [[ $_next_lines -eq 1 ]]; then
        LOG_LINES="$_a"
        _next_lines=0
    elif [[ "$_a" == "--now" ]]; then
        NOW=1
    elif [[ "$_a" == "--errors" ]]; then
        LOG_LEVEL="error|warn|crit|fail"
    elif [[ "$_a" == "--log" ]]; then
        WITH_LOG=1
    elif [[ "$_a" == "--level" ]]; then
        _next_level=1
    elif [[ "$_a" == --level=* ]]; then
        LOG_LEVEL="${_a#--level=}"
        LOG_LEVEL="${LOG_LEVEL//,/|}"
    elif [[ "$_a" == "--lines" ]]; then
        _next_lines=1
    elif [[ "$_a" == --lines=* ]]; then
        LOG_LINES="${_a#--lines=}"
    elif [[ "$_a" == "--as-user" ]]; then
        _next_as_user=1
    elif [[ "$_a" == --as-user=* ]]; then
        AS_USER="${_a#--as-user=}"
    else
        _args+=("$_a")
    fi
done
set -- "${_args[@]}"
unset _args _a _next_level _next_as_user _next_lines

# Apply --as-user: validate, override paths, check access
if [[ -n "$AS_USER" ]]; then
    _as_home=$(getent passwd "$AS_USER" 2>/dev/null | cut -d: -f6)
    [[ -z "$_as_home" ]] && _error "user '$AS_USER' not found"

    USER_MODE=1
    SVDIR="${_as_home}/.runit/sv"
    RUNSVDIR="${_as_home}/.runit/runsvdir"
    LOG_FILE="${_as_home}/.runit/log/everything/current"

    _as_ok=1
    for _chk in "$SVDIR" "$RUNSVDIR"; do
        _d="$_chk"
        while [[ -n "$_d" && "$_d" != "/" && ! -e "$_d" ]]; do
            _d=$(dirname "$_d")
        done
        [[ ! -r "$_d" || ! -w "$_d" ]] && _as_ok=0
    done
    if [[ $_as_ok -eq 0 ]]; then
        _error_hint "no read/write access to $AS_USER's runit directories" \
            "try running as root or ensure you have permission"
    fi
    unset _as_home _as_ok _chk _d
fi

# --- Helpers ------------------------------------------------------------------

_NEEDS_ROOT=(start stop restart enable disable reload edit new log-setup)

_check_root() {
    if [[ $EUID -ne 0 ]]; then
        _error "command '$1' requires root (or use --user for user services)"
    fi
}

_needs_root() {
    [[ $USER_MODE -eq 1 ]] && return 1  # user mode never needs root
    local cmd="$1"
    for c in "${_NEEDS_ROOT[@]}"; do
        [[ "$c" == "$cmd" ]] && return 0
    done
    return 1
}

_check_service_exists() {
    if [[ ! -d "$SVDIR/$1" ]]; then
        if [[ $USER_MODE -eq 1 ]]; then
            local sys_svdir="/etc/runit/sv"
            if [[ -d "$sys_svdir/$1" ]]; then
                _error_hint "service '$1' not found in $SVDIR" \
                    "did you mean: sudo rsv $CMD $1"
            fi
        else
            local user_svdir="${RUNIT_SVDIR:-$HOME/.runit/sv}"
            if [[ -d "$user_svdir/$1" ]]; then
                _error_hint "service '$1' not found in $SVDIR" \
                    "did you mean: rsv --user $CMD $1"
            fi
        fi
        _error_hint "service '$1' not found in $SVDIR" \
            "run 'rsv list' to see available services"
    fi
}

_check_service_enabled() {
    if [[ ! -L "$RUNSVDIR/$1" ]]; then
        _error_hint "service '$1' is not enabled" "run rsv enable --now $1 to enable and start it"
    fi
}
_is_internal() {
    [[ "$1" == "current" || "$1" == "supervise" || "$1" == ".supervisor" ]]
}

# Log level filter helpers (passthrough when LOG_LEVEL is unset)
_lgrep()      { [[ -n "$LOG_LEVEL" ]] && grep -aiE "$LOG_LEVEL"                   || cat; }
_lgrep_live() { [[ -n "$LOG_LEVEL" ]] && grep --line-buffered -aiE "$LOG_LEVEL"   || grep --line-buffered -a ''; }

# sv wrapper: in user mode pass the full service path instead of just the name
_sv() {
    if [[ $USER_MODE -eq 1 ]]; then
        local cmd="$1"; shift
        sv "$cmd" "$SVDIR/$1"
    else
        sv "$@"
    fi
}

# When sudo strips $EDITOR, look it up from the real user's login shell
_editor() {
    local ed="${EDITOR:-${VISUAL:-}}"
    if [[ -z "$ed" && -n "$SUDO_USER" ]]; then
        ed=$(su - "$SUDO_USER" -c 'printenv EDITOR 2>/dev/null || printenv VISUAL 2>/dev/null' 2>/dev/null)
    fi
    echo "${ed:-vi}"
}

# --- User-mode supervisor management ------------------------------------------

cmd_init() {
    [[ $USER_MODE -eq 0 ]] && _error "'init' is only for user mode (use --user or run as non-root)"

    if pgrep -u "$USER" -f "runsvdir.*$RUNSVDIR" >/dev/null 2>&1; then
        _warn "user runsvdir is already running"
        exit 0
    fi

    mkdir -p "$SVDIR" "$RUNSVDIR" "$(dirname "$LOG_FILE")"

    nohup runsvdir "$RUNSVDIR" >/dev/null 2>&1 &
    disown
    _ok "user runsvdir started (PID $!)"
    _info "tip: add 'rsv --user init' to your session startup (~/.profile, ~/.xinitrc, etc.)"
}

# --- Service commands ---------------------------------------------------------

cmd_start() {
    _check_service_exists "$1"
    _check_service_enabled "$1"
    _sv start "$1" && _ok "started '$1'" || _error "failed to start '$1'"
}

cmd_stop() {
    _check_service_exists "$1"
    _check_service_enabled "$1"
    _sv stop "$1" && _ok "stopped '$1'" || _error "failed to stop '$1'"
}

cmd_restart() {
    _check_service_exists "$1"
    _check_service_enabled "$1"
    _sv restart "$1" && _ok "restarted '$1'" || _error "failed to restart '$1'"
}

cmd_reload() {
    _check_service_exists "$1"
    _check_service_enabled "$1"
    _sv reload "$1" && _ok "reloaded '$1'" || _error "failed to reload '$1' (service may not support reload)"
}

cmd_enable() {
    _check_service_exists "$1"
    if [[ -L "$RUNSVDIR/$1" ]]; then
        _warn "service '$1' is already enabled"
        [[ $NOW -eq 1 ]] && { _sv start "$1" && _ok "started '$1'" || _error "failed to start '$1'"; }
        exit 0
    fi
    mkdir -p "$RUNSVDIR"
    ln -s "$SVDIR/$1" "$RUNSVDIR/$1"
    _ok "enabled '$1'"
    [[ $NOW -eq 1 ]] && { _sv start "$1" && _ok "started '$1'" || _error "failed to start '$1'"; }
}

cmd_disable() {
    _check_service_exists "$1"
    if [[ ! -L "$RUNSVDIR/$1" ]]; then
        _warn "service '$1' is not enabled"
        exit 0
    fi
    _sv stop "$1" 2>/dev/null
    rm "$RUNSVDIR/$1"
    _ok "disabled '$1'"
}

cmd_edit() {
    _check_service_exists "$1"
    local script="$SVDIR/$1/run"
    [[ ! -f "$script" ]] && _error "no run script at $script"
    "$(_editor)" "$script"
}

cmd_new() {
    local name="$1"
    [[ -d "$SVDIR/$name" ]] && _error "service '$name' already exists in $SVDIR"
    mkdir -p "$SVDIR/$name"
    cat > "$SVDIR/$name/run" << 'RUNEOF'
#!/bin/sh
exec /usr/bin/COMMAND 2>&1
RUNEOF
    chmod +x "$SVDIR/$name/run"
    _ok "created '$name' at $SVDIR/$name/run"

    if [[ $WITH_LOG -eq 1 ]]; then
        local logdir="$SVDIR/$name/log"
        if [[ $USER_MODE -eq 1 ]]; then
            local logdest="$HOME/.runit/log/$name"
        else
            local logdest="/var/log/$name"
        fi
        mkdir -p "$logdir" "$logdest"
        cat > "$logdir/run" << LOGEOF
#!/bin/sh
exec svlogd -tt $logdest
LOGEOF
        chmod +x "$logdir/run"
        _ok "created log service → $logdest"
    fi

    _info "edit the run script:  rsv edit $name"
    _info "enable when ready:    rsv enable $name"
}

cmd_doctor() {
    local issues=0

    # Check supervisor is running
    if [[ $USER_MODE -eq 1 ]]; then
        if ! pgrep -u "$USER" -f "runsvdir.*$RUNSVDIR" >/dev/null 2>&1; then
            echo -e "  ${RED}[fail]${NC} user runsvdir is not running (start with: rsv --user init)"
            (( issues++ ))
        else
            echo -e "  ${GREEN}[ok]${NC}   user runsvdir is running"
        fi
    else
        if ! sv status /run/runit/stopit >/dev/null 2>&1 && ! pgrep -x runsvdir >/dev/null 2>&1; then
            echo -e "  ${YELLOW}[warn]${NC} cannot verify system runsvdir (check your init)"
        else
            echo -e "  ${GREEN}[ok]${NC}   system runsvdir appears running"
        fi
    fi

    # Check for dangling symlinks in RUNSVDIR
    if [[ -d "$RUNSVDIR" ]]; then
        for link in "$RUNSVDIR"/*/; do
            [[ -L "${link%/}" ]] || continue
            local name
            name=$(basename "${link%/}")
            _is_internal "$name" && continue
            if [[ ! -d "$RUNSVDIR/$name" ]]; then
                echo -e "  ${RED}[fail]${NC} dangling symlink: $name → $(readlink "$RUNSVDIR/$name") (target missing)"
                (( issues++ ))
            fi
        done
        # Also catch non-trailing-slash symlinks
        for link in "$RUNSVDIR"/*; do
            [[ -L "$link" ]] || continue
            local name
            name=$(basename "$link")
            _is_internal "$name" && continue
            if [[ ! -e "$link" ]]; then
                echo -e "  ${RED}[fail]${NC} dangling symlink: $name → $(readlink "$link") (target missing)"
                (( issues++ ))
            fi
        done
    fi

    # Check each enabled service for missing/non-executable run script and down state
    if [[ -d "$RUNSVDIR" ]]; then
        for link in "$RUNSVDIR"/*; do
            [[ -L "$link" && -e "$link" ]] || continue
            local name
            name=$(basename "$link")
            _is_internal "$name" && continue

            local run="$SVDIR/$name/run"
            if [[ ! -f "$run" ]]; then
                echo -e "  ${RED}[fail]${NC} $name: missing run script at $run"
                (( issues++ ))
            elif [[ ! -x "$run" ]]; then
                echo -e "  ${RED}[fail]${NC} $name: run script is not executable ($run)"
                (( issues++ ))
            fi

            local out
            out=$(_sv status "$name" 2>/dev/null)
            if echo "$out" | grep -q "run:"; then
                : # up, already covered by run script check
            else
                echo -e "  ${YELLOW}[warn]${NC} $name: service is down"
            fi
        done
    fi

    if [[ $issues -eq 0 ]]; then
        _ok "no issues found"
    else
        echo ""
        _warn "$issues issue(s) found"
    fi
}

cmd_log_setup() {
    local name="$1"
    _check_service_exists "$name"

    local logdir="$SVDIR/$name/log"
    if [[ -f "$logdir/run" ]]; then
        _warn "log service already exists at $logdir/run"
        exit 0
    fi

    local logdest
    if [[ $USER_MODE -eq 1 ]]; then
        logdest="$HOME/.runit/log/$name"
    else
        logdest="/var/log/$name"
    fi

    mkdir -p "$logdir" "$logdest"
    cat > "$logdir/run" << LOGEOF
#!/bin/sh
exec svlogd -tt $logdest
LOGEOF
    chmod +x "$logdir/run"
    _ok "created log service for '$name'"
    _ok "logs will go to: $logdest"
    _info "restart the service to activate logging: rsv restart $name"
}

cmd_logs() {
    if [[ -n "$1" ]]; then
        _check_service_exists "$1"
        local log="$SVDIR/$1/log/current"
        if [[ -f "$log" ]]; then
            tail -f "$log" | _lgrep_live
        elif [[ -f "$LOG_FILE" ]]; then
            _warn "no per-service log at $log — falling back to global log (filtered)"
            _info "tip: add a log/run script to your service to enable per-service logging"
            tail -n "$((LOG_LINES * 100))" "$LOG_FILE" | grep -av '\[sudo\]' | grep -ai "$1" | _lgrep | tail -"$LOG_LINES"
            _info "following new entries (Ctrl-C to stop)..."
            tail -f "$LOG_FILE" | grep --line-buffered -av '\[sudo\]' | grep --line-buffered -ai "$1" | _lgrep_live
        else
            _error "no per-service log at $log and no global log at $LOG_FILE"
        fi
    else
        if [[ ! -f "$LOG_FILE" ]]; then
            _error "no global log at $LOG_FILE"
        fi
        tail -f "$LOG_FILE" | _lgrep_live
    fi
}

cmd_status() {
    if [[ -n "$1" ]]; then
        _check_service_exists "$1"
        _check_service_enabled "$1"
        local out
        out=$(_sv status "$1" 2>&1)
        if echo "$out" | grep -q "run:"; then
            echo -e "${GREEN}${out}${NC}"
        else
            echo -e "${RED}${out}${NC}"
        fi
        echo ""
        if [[ -f "$LOG_FILE" ]]; then
            _info "Recent log entries:"
            grep -ai "$1" "$LOG_FILE" | grep -ai "error\|warn\|fail\|crit" | tail -10
            [[ $? -ne 0 ]] && echo "  no errors found in log"
        fi
    else
        if [[ $USER_MODE -eq 1 ]]; then
            _info "Enabled user services:"
        else
            _info "Enabled services:"
        fi
        for svc in "$RUNSVDIR"/*/; do
            [[ -d "$svc" ]] || continue
            svc=$(basename "$svc")
            _is_internal "$svc" && continue
            local out
            out=$(_sv status "$svc" 2>/dev/null)
            if echo "$out" | grep -q "run:"; then
                echo -e "  ${GREEN}[up]  ${NC} $svc"
            else
                echo -e "  ${RED}[down]${NC} $svc"
            fi
        done
    fi
}

cmd_list() {
    if [[ $USER_MODE -eq 1 ]]; then
        _info "Available user services (in $SVDIR):"
    else
        _info "Available services:"
    fi
    [[ -d "$SVDIR" ]] || { _warn "service directory $SVDIR does not exist"; exit 0; }
    for svc in "$SVDIR"/*/; do
        [[ -d "$svc" ]] || continue
        svc=$(basename "$svc")
        _is_internal "$svc" && continue
        if [[ -L "$RUNSVDIR/$svc" ]]; then
            local out
            out=$(_sv status "$svc" 2>/dev/null)
            if echo "$out" | grep -q "run:"; then
                echo -e "  ${GREEN}[enabled/up]  ${NC} $svc"
            else
                echo -e "  ${YELLOW}[enabled/down]${NC} $svc"
            fi
        else
            echo -e "  ${RED}[disabled]    ${NC} $svc"
        fi
    done
}

# --- Usage --------------------------------------------------------------------

usage() {
    echo -e "${BOLD}rsv${NC} - runit service manager"
    echo ""
    echo -e "${BOLD}usage:${NC} rsv [--user] <command> [service]"
    echo ""
    echo -e "${BOLD}flags:${NC}"
    echo "  --user              operate on user services (auto-set when not root)"
    echo "  --as-user <user>    manage another user's services (requires r/w access)"
    echo "  --now               with enable: also start the service immediately"
    echo "  --errors            with logs: show only error/warn/crit/fail lines"
    echo "  --level <levels>    with logs: filter by level e.g. --level error,warn"
    echo "  --lines <N>         with logs: show last N matching lines (default 10)"
    echo "  --log               with new: also scaffold a log service"
    echo ""
    echo -e "${BOLD}commands:${NC}"
    echo "  init                start the user runsvdir supervisor (user mode only)"
    echo "  start   <service>   start a service"
    echo "  stop    <service>   stop a service"
    echo "  restart <service>   restart a service"
    echo "  reload  <service>   reload a service"
    echo "  enable  <service>   enable a service"
    echo "  disable <service>   disable a service"
    echo "  status  [service]   show status of one or all enabled services"
    echo "  list                list all available services and their state"
    echo "  logs    [service]   tail logs for a service (or global log)"
    echo "  edit    <service>   open the service run script in \$EDITOR"
    echo "  new     <service>   scaffold a new service (--log to include log service)"
    echo "  doctor              check for common runit configuration problems"
    echo "  log-setup <service> add a svlogd log service to an existing service"
    echo ""
    echo -e "${BOLD}system paths (root):${NC}"
    echo "  sv dir:   /etc/runit/sv"
    echo "  run dir:  /etc/runit/runsvdir/default"
    echo ""
    echo -e "${BOLD}user paths:${NC}"
    echo "  sv dir:   ~/.runit/sv          (override: \$RUNIT_SVDIR)"
    echo "  run dir:  ~/.runit/runsvdir    (override: \$RUNIT_RUNSVDIR)"
    echo ""
    echo -e "${BOLD}commands requiring root (system mode):${NC} start stop restart reload enable disable"
}

# --- Dispatch -----------------------------------------------------------------

CMD="$1"  # used by _check_service_exists for cross-mode hints

if _needs_root "$1"; then
    _check_root "$1"
fi

case "$1" in
    init)     [[ $USER_MODE -eq 0 ]] && _error "'init' is only available in user mode" || cmd_init ;;
    start)    [[ -z "$2" ]] && usage || cmd_start "$2" ;;
    stop)     [[ -z "$2" ]] && usage || cmd_stop "$2" ;;
    restart)  [[ -z "$2" ]] && usage || cmd_restart "$2" ;;
    reload)   [[ -z "$2" ]] && usage || cmd_reload "$2" ;;
    enable)   [[ -z "$2" ]] && usage || cmd_enable "$2" ;;
    disable)  [[ -z "$2" ]] && usage || cmd_disable "$2" ;;
    status)   cmd_status "$2" ;;
    list)     cmd_list ;;
    logs)     cmd_logs "$2" ;;
    edit)      [[ -z "$2" ]] && usage || cmd_edit "$2" ;;
    new)       [[ -z "$2" ]] && usage || cmd_new "$2" ;;
    doctor)    cmd_doctor ;;
    log-setup) [[ -z "$2" ]] && usage || cmd_log_setup "$2" ;;
    *)         usage ;;
esac
